---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { getCategoriesWithExpenseCounts } from "@/lib/services/categories";
import type { CategoryWithCount } from "@/types";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const serverError = Astro.url.searchParams.get("error");

let categories: CategoryWithCount[] = [];

if (supabase && user) {
  categories = await getCategoriesWithExpenseCounts(supabase, user.id);
}

const atCap = categories.length >= 20;
---

<Layout title="Categories — BudgetFlow">
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto max-w-md space-y-6 py-6">
      <!-- Header -->
      <div class="flex items-center justify-between text-white">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
            BudgetFlow
          </h1>
          <p class="text-sm text-blue-100/60">{user?.email}</p>
        </div>
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 text-sm text-white transition-colors hover:bg-white/20"
          >
            Sign out
          </button>
        </form>
      </div>

      <!-- Back link -->
      <a href="/dashboard" class="block text-sm text-blue-100/60 transition-colors hover:text-white">
        ← Back to dashboard
      </a>

      <!-- Error banner -->
      {
        serverError && (
          <div class="rounded-2xl border border-red-400/20 bg-red-500/10 p-4 text-sm text-red-300">{serverError}</div>
        )
      }

      <!-- Add category card -->
      <div class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
        <h2 class="mb-4 text-lg font-semibold text-white">Add category</h2>
        {
          atCap ? (
            <p class="text-center text-sm text-blue-100/50">Maximum 20 categories reached.</p>
          ) : (
            <form method="POST" action="/api/categories" class="flex gap-2">
              <input
                type="text"
                name="name"
                maxlength="50"
                required
                placeholder="Category name"
                class="flex-1 rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 transition-colors focus:ring-2 focus:ring-purple-400 focus:outline-none"
              />
              <button
                type="submit"
                class="rounded-lg bg-purple-500/80 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-purple-500"
              >
                Add
              </button>
            </form>
          )
        }
      </div>

      <!-- Categories list card -->
      <div class="rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl">
        <div class="mb-4 flex items-center gap-2">
          <h2 class="text-lg font-semibold text-white">Categories</h2>
          <span class="text-sm text-blue-100/50">({categories.length} / 20)</span>
        </div>
        {
          categories.length === 0 ? (
            <p class="text-center text-sm text-blue-100/50">No categories yet.</p>
          ) : (
            <ul class="space-y-2">
              {categories.map((cat) => (
                <li class="flex items-center justify-between rounded-lg border border-white/10 bg-white/5 px-4 py-3">
                  <div>
                    <span class="text-sm font-medium text-white">{cat.name}</span>
                    <span class="ml-2 text-xs text-blue-100/50">
                      {cat.expense_count} expense{cat.expense_count !== 1 ? "s" : ""}
                    </span>
                  </div>
                  <form method="POST" action={`/api/categories/${cat.id}`}>
                    <button type="submit" class="text-xs text-red-300/70 transition-colors hover:text-red-300">
                      Delete
                    </button>
                  </form>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </div>
</Layout>
