---
import Layout from "@/layouts/Layout.astro";
import ForgotPasswordForm from "@/components/auth/ForgotPasswordForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Reset password">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-sm rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-2 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Reset password
      </h1>
      <p class="mb-6 text-center text-sm text-blue-100/60">Enter your email and we'll send you a reset link.</p>
      <ForgotPasswordForm serverError={error} client:load />
      <p class="mt-4 text-center text-sm text-blue-100/60">
        <a href="/auth/signin" class="text-purple-300 hover:underline">Back to sign in</a>
      </p>
    </div>
  </div>
</Layout>
