# Integration test environment — copy to .env.test and fill in values.
# Prerequisites: npx supabase start (Docker required)
# Get key values from: npx supabase status

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=       # "Publishable" key from `npx supabase status`
SUPABASE_SERVICE_ROLE_KEY=  # "Secret" key from `npx supabase status`
